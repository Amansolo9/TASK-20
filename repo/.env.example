# Copy to .env for production deployment.
# SESSION_KEY and HMAC_SECRET are auto-generated with warnings if not set.
# FIELD_ENCRYPTION_KEY uses a deterministic dev fallback in debug mode;
# it is REQUIRED when GIN_MODE=release. Generate with: openssl rand -base64 32

FIELD_ENCRYPTION_KEY=
SESSION_KEY=
HMAC_SECRET=
SECURE_COOKIES=false
# Set GIN_MODE=release for production (enforces FIELD_ENCRYPTION_KEY requirement)
# GIN_MODE=release
